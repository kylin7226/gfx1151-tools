# 复制为 .env 并填写。
#
# 只有 VLLM_HOST_MODELS_DIR 是必填项。
# 其他参数都有合理的默认值。

# HuggingFace 模型缓存目录的绝对路径。
# 必须包含 hub/ 子目录，且已下载好模型快照：
#   hf download cyankiwi/Qwen3.6-27B-AWQ-INT4 --cache-dir $VLLM_HOST_MODELS_DIR/hub
VLLM_HOST_MODELS_DIR=/absolute/path/to/hf-cache

# HuggingFace 令牌。cyankiwi AWQ-INT4 量化模型是公开的（Apache 2.0），
# 但基础模型 Qwen/Qwen3.6-27B 是 gated model，下载路径通过基础模型
# 解析时仍需要令牌。在 https://huggingface.co/settings/tokens 创建令牌。
# 仅用于 `hf download` 缓存阶段；容器内运行时不需要（HF_HUB_OFFLINE=1）。
HF_TOKEN=hf_your_token_here

# 主机侧持久化缓存目录（跨容器重启存活，
# 后续启动跳过约 3 分钟的内核编译）。
# 未设置时默认为本地的 .triton-cache/ 和 .vllm-cache/。
#VLLM_HOST_TRITON_CACHE=/absolute/path/to/triton-cache
#VLLM_HOST_VLLM_CACHE=/absolute/path/to/vllm-cache

# 主机侧端口。如果 8000 被占用可更换。
VLLM_HOST_PORT=8000

# 模型 ID 或本地路径。默认是我们测试过的 AWQ-INT4 量化模型。
# `cyankiwi/Qwen3.6-27B-AWQ-INT4` 是 4-bit AWQ（compressed-tensors
# 方案，group_size 32），保留视觉塔以便 /v1/chat 图像输入正常工作。
VLLM_MODEL_ID=cyankiwi/Qwen3.6-27B-AWQ-INT4
VLLM_SERVED_MODEL_NAME=Qwen3.6-27B-AWQ4

# 并发服务槽位。1 表示单用户推理；如果需要多用户可提高。
# AWQ4 相比 BF16 释放约 37 GiB UMA，在此硬件上额外槽位是可行的。
VLLM_MAX_NUM_SEQS=1

# GPU 显存利用率（vLLM 可使用的 UMA 比例）。
# 0.9 保留约 12 GiB GTT 余量，供 DeltaNet GDN Triton
# 自动调优在第一个真实请求时使用（vllm#36598）。
# 如果自动调优 OOM，可降到 0.85。
VLLM_GPU_MEMORY_UTIL=0.9

# 最大上下文窗口。Qwen 3.6 27B 原生最大为 262144（256K）。
# 减少此值不会节省计算量——只是限制你能发送的最长 prompt。
# 除非你知道自己在做什么，否则保持原生值。
VLLM_MAX_MODEL_LEN=262144

# vLLM 构建版本。默认为 v0.20.1 发布标签（2026-05-01），包含：
#   - PR #36505: AWQMarlin on ROCm（AWQ prefill +57% / decode +73%）
#   - RDNA 3.5/4 设备 ID 检测（gfx1150/1151/1201）
#   - Qwen3-Next / Qwen3.5 初始 GDN 注意力
#
# 可设置为 sha 或分支名来覆盖。留空则跟踪 HEAD。
# 注意：工具调用解析器 PR #40783（开放）、#40785（关闭未合并）、
# #40787（关闭未合并）不在 0.20.0 中；流式工具调用仍然脆弱。
# 等重构合并后可固定到合并后的 sha。
VLLM_COMMIT=v0.20.1

# ── Qwen3-ASR（语音转文字）──────────────────────────────────────
#
# 独立的 vLLM 容器，端口 8001。支持三种模式：
#   POST /v1/audio/transcriptions          → 非流式 JSON/text
#   POST /v1/audio/transcriptions?stream   → SSE 流式
#   ws://host:8001/v1/realtime             → WebSocket PCM16 实时
#
# 预下载：
#   hf download Qwen/Qwen3-ASR-8B --cache-dir $VLLM_HOST_MODELS_DIR/hub
VLLM_ASR_MODEL_ID=Qwen/Qwen3-ASR-8B
VLLM_ASR_HOST_PORT=8001
VLLM_ASR_GPU_MEMORY_UTIL=0.9
VLLM_ASR_MAX_NUM_SEQS=1
VLLM_ASR_MAX_MODEL_LEN=8192

# ── vLLM-Omni（全模态推理）───────────────────────────────────────
#
# 独立的容器，端口 8002。支持文本、图像、视频、音频作为输入/输出。
# 基于 vllm-omni v0.20.0rc1（rebase 于 vLLM v0.20.0），带有 gfx1151
# 适配补丁。
#
# 预下载：
#   hf download Qwen/Qwen3-Omni-MoE-27B --cache-dir $VLLM_HOST_MODELS_DIR/hub
VLLM_OMNI_MODEL_ID=Qwen/Qwen3-Omni-MoE-27B
VLLM_OMNI_SERVED_MODEL_NAME=Qwen3-Omni-MoE-27B
VLLM_OMNI_HOST_PORT=8002
VLLM_OMNI_GPU_MEMORY_UTIL=0.9
VLLM_OMNI_MAX_NUM_SEQS=1
VLLM_OMNI_MAX_MODEL_LEN=8192
# vllm-omni 版本。默认为 v0.20.0rc1 发布标签。
VLLM_OMNI_COMMIT=v0.20.0rc1

# ── Qwen3-TTS（语音合成）───────────────────────────────────────
#
# 独立的 vLLM-Omni 容器，端口 8003。OpenAI 兼容的 /v1/audio/speech API。
# 支持三种模式：
#   CustomVoice  → 预设音色（默认 "vivian"），支持风格指令
#   VoiceDesign  → 通过文字描述创建全新音色
#   Base         → 声音克隆（提供参考音频 + 文字）
#
# 预下载：
#   hf download Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice --cache-dir $VLLM_HOST_MODELS_DIR/hub
VLLM_TTS_MODEL_ID=Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice
VLLM_TTS_HOST_PORT=8003
VLLM_TTS_GPU_MEMORY_UTIL=0.7
VLLM_TTS_MAX_NUM_SEQS=4
VLLM_TTS_MAX_MODEL_LEN=4096
